# Files excluded from the image build context.
# Anything in vendor/, node_modules/, .env* is regenerated inside the
# image, so excluding it from the build context keeps the build
# context small and the COPY . step fast.

# VCS + IDE
.git
.gitignore
.gitattributes
.github
.idea
.vscode
.fleet
.nova
.zed

# Secrets
.env
.env.*
!.env.example
!.env.docker

# Build artefacts we recreate inside the image
/vendor
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*.php

# Tests (kept in the repo for `php artisan test` inside the container,
# but excluded from the build context — Pest runs are container-side)
/tests

# Docs
/docs

# OS junk
.DS_Store
Thumbs.db

# Logs
*.log
